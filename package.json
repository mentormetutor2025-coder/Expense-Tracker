{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev":        "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build":      "npm install --prefix server && npm install --prefix client --legacy-peer-deps && npm run build --prefix client",
    "start":      "node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
